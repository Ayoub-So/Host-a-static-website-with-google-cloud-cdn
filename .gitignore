# Local .terraform directories
**/.terraform/*


# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files, as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan

# Ignore lock files (optional - for team projects, you might want to commit this)
.terraform.lock.hcl

# Ignore backend configuration
.terraform/backends/*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
*.code-workspace

# IDE specific files
.vs/
.vscode/settings.json
.vscode/extensions.json

# OS specific files
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.env
.venv

# Node.js
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# Build and dist files
dist/
build/
*.egg-info/
.eggs/

# Credentials and secrets
*.pem
*.key
*.crt
*.pfx
service-account-key.json
google-credentials.json
*.p8
*.p12

# GCP Service Account Keys
**/service-account*.json
**/key*.json

# Authentication tokens
.credentials/
.auth/
tokens/
secrets/

# Temporary files
*.tmp
*.temp
*.bak
*.backup
~*

# Log files
*.log
logs/

# Coverage reports
.coverage
coverage/
htmlcov/

# Cache directories
.cache/
__pycache__/
*.egg-info/

# Compiled files
*.o
*.obj
*.exe

# Environment files
.env
.env.local
.env.*.local

# MacOS
.DS_Store
._*
.AppleDouble
.apdisk

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory
*~

# Project-specific
.terraform.tfvars
terraform.tfvars.example

# Terraform state lock
.terraform.lock.hcl

# Backup files
*.backup
*.old
*.bak

# Generated files
!*.tf
!*.html
!*.css
!*.js
!*.json
!*.md
!*.txt
!*.yaml
!*.yml

# Keep important files
!.gitkeep
!README.md
!LICENSE
!.gitignore

# Local development
local/
tmp/
temp/

# IDE files
.project
.pydevproject
.settings/
.classpath

# Docker
.dockerignore
.docker/

# Miscellaneous
.ruby-version
.node-version
.nvmrc
*.swp
*.swo
*~
.tags
.ctags

# GCP related
gcp-keys/
.gcloud/
credentials.json

# Exclude sensitive data patterns
*secret*
*password*
*token*
*credential*
